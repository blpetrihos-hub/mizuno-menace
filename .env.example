# Copy this file to ".env" and fill in your eBay developer credentials.
# Get free credentials at https://developer.ebay.com/  ->  "My Account" -> Application Keys.
# You need the "App ID (Client ID)" and "Cert ID (Client Secret)" from a PRODUCTION keyset.

EBAY_CLIENT_ID=your-app-id-here
EBAY_CLIENT_SECRET=your-cert-id-here

# Optional. Use "production" (default) or "sandbox".
EBAY_ENV=production

# Optional. eBay marketplace, e.g. EBAY_US, EBAY_GB, EBAY_DE.
EBAY_MARKETPLACE_ID=EBAY_US
